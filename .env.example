# server/.env (never commit the real .env file)

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marshals
DB_USER=marshalapp
DB_PASSWORD=changeme

# JWT
JWT_SECRET=a-long-random-string-change-this
JWT_EXPIRY=12h

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=changeme
EMAIL_FROM_NAME=Marshpoint
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Coordinator name used in email templates
COORDINATOR_NAME=The Marshalling Team

# App
APP_BASE_URL=http://localhost:3000
UPLOAD_DIR=/var/marshal-uploads

# GDPR
# Bump when the substance of the privacy notice changes (recorded against each consent).
PRIVACY_POLICY_VERSION=1.0
# Retention window for `npm run retention` — personal data is anonymised this
# many days after a marshal's most recent event (default ~3 years).
RETENTION_DAYS=1095

# Server
PORT=3001
NODE_ENV=development
